# =========================================================================
# winnin-papers-agent — example environment configuration
# Copy this file to .env and fill in the secrets before running the stack.
# Values shown here are sensible defaults for local Docker Compose.
# =========================================================================

# === Gemini API ===
GEMINI_API_KEY=                                          # SecretStr - obtain at https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.5-flash-lite                           # chat model used by the orchestrator
GEMINI_EMBEDDING_MODEL=gemini-embedding-001                # embedding model (Google)

# === ChromaDB (vector store) ===
CHROMA_HOST=localhost                                    # compose service name OR localhost when running outside the network
CHROMA_PORT=8000                                         # port exposed by the chroma container
CHROMA_COLLECTION=papers                                 # collection name inside Chroma

# === Data ===
# Diretorio onde os 5 PDFs ficam montados (volume Docker pdfs:/app/pdfs).
PDF_DIR=/app/pdfs

# === SQLite (thread memory) ===
DATABASE_URL=sqlite+aiosqlite:////data/papers_agent.sqlite  # SQLAlchemy async URL (4 slashes = absolute /data)

# === Ingestion / RAG ===
CHUNK_SIZE=800                                           # approximate tokens per chunk
CHUNK_OVERLAP=100                                        # token overlap between consecutive chunks
TOP_K=5                                                  # number of chunks returned by search_documents

# === API ===
API_HOST=0.0.0.0                                         # uvicorn bind host (0.0.0.0 inside the container)
API_PORT=8080                                            # uvicorn port

# === Logging ===
LOG_LEVEL=INFO                                           # DEBUG / INFO / WARNING / ERROR
